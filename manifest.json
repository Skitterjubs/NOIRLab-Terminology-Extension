{
  "manifest_version": 3,
  "name": "Terminology",
  "description": "Provides quick access to official terminology and abbreviations directly from your browser.",
  "version": "0.0.1",
  "action": {
    "default_popup": "index.html"
  },
  "icons": {
    "16": "icon-16.png",
    "128": "icon-128.png"
  },
  "background": {
    "service_worker": "src/background.ts"
  },
  "permissions": ["storage", "alarms"]
}
